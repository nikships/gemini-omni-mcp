# Gemini Omni MCP configuration

# Required: Google Gemini API key
# Get one from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Alternative API key name
# GOOGLE_API_KEY=your_api_key_here

# Optional: Output directory for generated videos (default: ~/gemini_omni_videos)
# OUTPUT_DIR=~/gemini_omni_videos

# Optional: Prompt enhancement is disabled by default because video edits work best with simple prompts
# ENABLE_PROMPT_ENHANCEMENT=false

# Optional: Request and file polling settings
# REQUEST_TIMEOUT=300
# FILE_POLL_INTERVAL=5
# FILE_POLL_TIMEOUT=600
# MAX_BATCH_SIZE=4
# MAX_RETRIES=3

# Optional: Default generation settings
# DEFAULT_ASPECT_RATIO=16:9
# DEFAULT_DELIVERY=uri
# DEFAULT_DURATION_SECONDS=5

# Optional: Logging
# LOG_LEVEL=INFO
